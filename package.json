{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx prisma generate && vite build && tsc -p tsconfig.server.json",
    "build:client": "vite build",

    "build:server": "node scripts/build-server.js",

    "build:server": "tsc -p tsconfig.server.json", 

    "preview": "vite preview",
    "start": "npx prisma generate && (npx prisma db push --accept-data-loss 2>/dev/null || true) && node dist/server/index.js",
    "server": "tsx watch src/server/index.ts",
    "server:prod": "npm run start",
    "worker": "tsx watch src/server/worker.ts",
    "worker:prod": "node dist/server/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "npx ts-node prisma/seed.ts",
    "prisma:reset": "npx prisma migrate reset --force",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\" \"npm run worker\"",
    "deploy:coolify": "docker-compose -f docker-compose.prod.yml up -d",
    "deploy:build": "npm run build && docker build -t bizzauto .",
    "deploy": "npm run build && npm run start"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^5.2.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "cors": "^2.8.6",
    "cookie-parser": "^1.4.7",
    "compression": "^1.8.1",
    "morgan": "^1.10.1",
    "helmet": "^8.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.13.2"
   
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",

    
    "@vitejs/plugin-react": "5.1.1",
    "esbuild": "^0.28.0",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-singlefile": "2.3.0"

    "vite": "^7.3.2",
  
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"

  }
}
